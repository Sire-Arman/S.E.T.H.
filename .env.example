# ============ API KEYS ============
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Cohere
COHERE_API_KEY=your_cohere_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Deepgram (for Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ============ SERVER CONFIGURATION ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ============ LLM CONFIGURATION ============
# Default LLM provider: cohere, gemini, openai, anthropic
DEFAULT_LLM=cohere

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# Cohere Configuration
COHERE_MODEL=command-a-03-2025

# OpenAI Configuration
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============ SPEECH-TO-TEXT (STT) CONFIGURATION ============
# Deepgram Settings
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en

# ============ SYSTEM INSTRUCTION ============
SYSTEM_INSTRUCTION=You are a helpful voice assistant. Keep responses concise and conversational.

# ============ AGENT CONFIGURATION ============
# LLM provider for the LangGraph agent: cohere, ollama
AGENT_LLM=cohere

# Search provider: tavily
AGENT_SEARCH=tavily

# Tavily Search API Key (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Ollama model for agent (separate from voice model, must support tool calling)
OLLAMA_AGENT_MODEL=qwen3:8b

# ============ LOGGING ============
LOG_LEVEL=INFO
